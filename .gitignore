# Dependencies
node_modules/

# Build artefacts
dist/
build/
out/
*.tsbuildinfo

# VitePress docs site (SLS-32): build output, cache, and the report page
# synced in from eval/reports at build time (single-sourced there).
docs/.vitepress/dist/
docs/.vitepress/cache/
docs/benchmarks.md

# Environment
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Coverage
coverage/
.nyc_output/

# Python (services/mpc, services/rl) — keep uv.lock tracked for --frozen CI
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Playwright
playwright-report/
test-results/
playwright/.cache/

# Claude Code per-user settings (kept local)
.claude/settings.local.json

# Eval outputs (CI uploads them as artifacts; not versioned)
eval/results/*
# …but the curated milestone-gate records (SLS-67) are durable provenance and
# ARE tracked. Uses eval/results/* above (not eval/results/) so git descends
# into this re-included subdir.
!eval/results/gate-records/
eval/plots/

# RL training artifacts (SLS-29) — checkpoints & TB logs stay local
services/rl/checkpoints*/
services/rl/runs/
services/rl/eval/results/

# RL teacher demo datasets (SLS-51) — local only
# (covered by demos*/ below)
services/rl/demos*/
