{
  "name": "starship-catch-sim",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:full": "concurrently -n web,mpc -c cyan,magenta \"pnpm dev\" \"pnpm mpc:serve\"",
    "mpc:serve": "cd services/mpc && uv run uvicorn mpc.server:app --host 127.0.0.1 --port 8100",
    "mpc:test": "cd services/mpc && uv run pytest -q",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @starship-catch-sim/web exec playwright test",
    "playwright:install": "pnpm --filter @starship-catch-sim/web exec playwright install --with-deps chromium",
    "bench": "tsx tools/bench/physics-bench.ts",
    "eval:pid": "tsx tools/eval/pid-monte-carlo.ts",
    "eval:all": "tsx tools/eval/run-eval.ts",
    "plot": "tsx tools/eval/plot.ts",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.3",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fast-check": "^4.8.0",
    "globals": "^15.13.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.7"
  }
}
