{
  "name": "starship-catch-sim",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "dev:full": "concurrently -n web,mpc -c cyan,magenta \"pnpm dev\" \"pnpm mpc:serve\"",
    "mpc:serve": "cd services/mpc && uv run uvicorn mpc.server:app --host 127.0.0.1 --port 8100",
    "mpc:test": "cd services/mpc && uv run pytest -q",
    "build": "pnpm -r run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm --filter @starship-catch-sim/web exec playwright test",
    "playwright:install": "pnpm --filter @starship-catch-sim/web exec playwright install --with-deps chromium",
    "bake:terrain": "node tools/assets/bake-terrain.mjs",
    "gen:consts": "tsx tools/gen-physics-consts.ts",
    "gen:consts:check": "tsx tools/gen-physics-consts.ts --check",
    "gen:parity-fixtures": "tsx tools/eval/gen-parity-fixtures.ts",
    "gen:parity-fixtures:check": "tsx tools/eval/gen-parity-fixtures.ts --check",
    "rl:train": "cd services/rl && uv sync --group train && uv run python scripts/train_ppo.py --config configs/ppo-booster.yaml",
    "rl:eval": "cd services/rl && uv run python scripts/eval_policy.py --checkpoint checkpoints/latest.zip",
    "rl:campaign": "cd services/rl && uv sync --group train && nohup uv run python scripts/campaign.py --plan configs/campaign-night1.yaml > runs/campaign.log 2>&1 & echo 'campaign launched: tail -f services/rl/runs/campaign.log'",
    "bench": "tsx tools/bench/physics-bench.ts",
    "bench:mpc": "tsx tools/eval/mpc-bench.ts",
    "bench:rl": "tsx tools/eval/rl-bench.ts",
    "eval:pid": "tsx tools/eval/pid-monte-carlo.ts",
    "eval:all": "tsx tools/eval/run-eval.ts",
    "plot": "tsx tools/eval/plot.ts",
    "chart:progression": "tsx tools/eval/progression-chart.ts",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.7",
    "concurrently": "^10.0.3",
    "draco3d": "^1.5.7",
    "eslint": "^9.16.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "fast-check": "^4.8.0",
    "geotiff": "^3.0.5",
    "globals": "^15.13.0",
    "jpeg-js": "^0.4.4",
    "meshoptimizer": "^1.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.22.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.1.7"
  }
}
